void HandleConfirmedEntry(string msg) { 
    var parts = msg.Split('|'); if (parts.Length < 4) return; 
    string output = $"CONFIRMED ENTRY\nName: {parts[1]}\nGPS: {parts[2]}"; 
    if (lcdConfirm != null) { lcdConfirm.ContentType = VRage.Game.GUI.TextPanel.ContentType.TEXT_AND_IMAGE; lcdConfirm.WriteText(output); } 
    if (indicatorLight != null) { indicatorLight.Color = blinkColor; indicatorLight.Enabled = true; blinkRequested = true; blinkTicks = 0; } 
    if (soundBlock != null) { soundBlock.SelectedSound = "Alert 2"; soundBlock.Play(); } 
    if (parts[1].Equals("ExcavationSiteEntry1", StringComparison.OrdinalIgnoreCase)) {
        Vector3D p;
        if (TryParseGPS(parts[2], out p)) { entry1Target = p; hasEntry1Target = true; }
        Vector3D f, u;
        if (TryParseOrientation(parts[3], out f, out u)) { entry1Forward = f; entry1Up = u; }
    }
    if (recordingActive) { Vector3D p; if (TryParseGPS(parts[2], out p)) { recordingLastGPS = p; recordingTimer = 0; recordingPaused = false; } } 
} 

void UpdateEntry1ProximityIndicator() {
    if (!entry1ProximityEnabled || !hasEntry1Target || indicatorLight == null || remote == null) return;
    double d = Vector3D.Distance(remote.GetPosition(), entry1Target);
    if (d > ENTRY1_RED_DISTANCE) return; // outside 50m = normal indicator behavior
    double t;
    if (d <= ENTRY1_GREEN_DISTANCE) t = 1;
    else t = (ENTRY1_RED_DISTANCE - d) / (ENTRY1_RED_DISTANCE - ENTRY1_GREEN_DISTANCE);
    int r = (int)MathHelper.Clamp(255 * (1 - t), 0, 255);
    int g = (int)MathHelper.Clamp(255 * t, 0, 255);
    indicatorLight.Color = new Color(r, g, 0);
    indicatorLight.Enabled = true;
}

bool UpdateAutopilotIndicator() {
    if (indicatorLight == null) return false;
    bool ap = autoReturnToStaggerActive || undoReturnActive || undockActive || undockToEntryActive || dockStraightActive || dockActive || automineActive || isSoftLocked;
    if (!ap) { indicatorLight.Enabled = false; return false; }
    indicatorLight.Color = new Color(0, 100, 255);
    indicatorLight.Enabled = true;
    return true;
}

void StartUndock() {
    if (remote == null) return;
    if (connector != null && connector.Status == MyShipConnectorStatus.Connected) connector.Disconnect();
    undockStartPos = remote.GetPosition();
    undockMoveDir = connector != null ? Vector3D.Normalize(connector.WorldMatrix.Backward) : Vector3D.Normalize(-remote.WorldMatrix.Forward);
    undockHoldForward = remote.WorldMatrix.Forward;
    undockHoldUp = remote.WorldMatrix.Up;
    undockLiveRefreshTimer = 0;
    undockToEntryActive = false;
    undockActive = true;
    BroadcastCarrier("LiveDockDataRequest");
    Echo("[Undock] Starting straight undock.");
}

void ApplyUndock(double dt) {
    if (remote == null) return;
    if (remote.MoveIndicator.LengthSquared() > 0.05f || remote.RotationIndicator.LengthSquared() > 0.05f || Math.Abs(remote.RollIndicator) > 0.05f) {
        undockActive = false;
        StopOverrides();
        Echo("[Undock] Canceled by pilot input.");
        return;
    }
    undockLiveRefreshTimer += dt;
    if (undockLiveRefreshTimer >= 0.5) {
        undockLiveRefreshTimer = 0;
        BroadcastCarrier("LiveDockDataRequest");
    }
    Vector3D holdF = hasEntry1Target ? entry1Forward : undockHoldForward;
    Vector3D holdU = hasEntry1Target ? entry1Up : undockHoldUp;
    gyroControl?.FaceVectors(holdF, holdU, dt);
    Vector3D traveled = remote.GetPosition() - undockStartPos;
    double progress = Vector3D.Dot(traveled, undockMoveDir);
    if (progress >= connectorApproachDistance) {
        undockActive = false;
        StopThrusterOverrides();
        if (hasEntry1Target) {
            undockToEntryActive = true;
            Echo($"[Undock] Completed {connectorApproachDistance:0.##}m. Continuing to Entry1.");
        } else {
            StopOverrides();
            Echo($"[Undock] Completed {connectorApproachDistance:0.##}m straight departure (no Entry1 target).");
        }
        return;
    }

    double remaining = connectorApproachDistance - progress;
    Vector3D desiredVel = undockMoveDir * MathHelper.Clamp(remaining / 4.0, 0.4, 1.6);
    Vector3D velErr = desiredVel - remote.GetShipVelocities().LinearVelocity;
    List<IMyThrust> thrusters = new List<IMyThrust>();
    GridTerminalSystem.GetBlocksOfType(thrusters);
    foreach (var t in thrusters) {
        Vector3D accelDir = -t.WorldMatrix.Forward;
        double thrustDemand = Vector3D.Dot(velErr, accelDir);
        t.ThrustOverride = thrustDemand > 0.05 ? (float)(thrustDemand * 180000) : 0f;
    }
}

void ApplyUndockToEntry(double dt) {
    if (remote == null || !hasEntry1Target) {
        undockToEntryActive = false;
        StopOverrides();
        Echo("[Undock] No Entry1 target. Transit stopped.");
        return;
    }
    if (remote.MoveIndicator.LengthSquared() > 0.05f || remote.RotationIndicator.LengthSquared() > 0.05f || Math.Abs(remote.RollIndicator) > 0.05f) {
        undockToEntryActive = false;
        StopOverrides();
        Echo("[Undock] Entry transit canceled by pilot input.");
        return;
    }

    Vector3D delta = entry1Target - remote.GetPosition();
    double distance = delta.Length();
    undockLiveRefreshTimer += dt;
    if (undockLiveRefreshTimer >= 0.5) {
        undockLiveRefreshTimer = 0;
        BroadcastCarrier("LiveDockDataRequest");
    }
    // Prefer live Ca entry orientation while transiting.
    Vector3D holdF = hasEntry1Target ? entry1Forward : undockHoldForward;
    Vector3D holdU = hasEntry1Target ? entry1Up : undockHoldUp;
    gyroControl?.FaceVectors(holdF, holdU, dt);

    if (distance <= 2.0) {
        undockToEntryActive = false;
        StopOverrides();
        Echo("[Undock] Reached Entry1.");
        return;
    }

    Vector3D desiredVel = Vector3D.Zero;
    if (distance > 0.01)
        desiredVel = Vector3D.Normalize(delta) * MathHelper.Clamp(distance / 6.0, 0.3, 1.6);
    Vector3D velErr = desiredVel - remote.GetShipVelocities().LinearVelocity;
    List<IMyThrust> thrusters = new List<IMyThrust>();
    GridTerminalSystem.GetBlocksOfType(thrusters);
    foreach (var t in thrusters) {
        Vector3D accelDir = -t.WorldMatrix.Forward;
        double thrustDemand = Vector3D.Dot(velErr, accelDir);
        t.ThrustOverride = thrustDemand > 0.05 ? (float)(thrustDemand * 180000) : 0f;
    }
}

void StartDock()
{
    if (remote == null) return;
    if (!hasEntry1Target || !hasLiveConnectorTarget) { Echo("[Dock] Waiting for live dock data."); return; }
    double dEntry = Vector3D.Distance(remote.GetPosition(), entry1Target);
    if (dEntry > ENTRY1_RED_DISTANCE) { Echo("[Dock] Move inside Entry1 50m bubble first."); return; }
    dockHoldForward = remote.WorldMatrix.Forward;
    dockHoldUp = remote.WorldMatrix.Up;
    dockStraightStartPos = remote.GetPosition();
    dockStraightActive = true;
    dockActive = false;
    pendingDockStart = false;
    dockRefreshTimer = 0;
    Echo($"[Dock] Starting staging approach ({connectorApproachDistance:0.##}m).");
}

void ApplyDockStraight(double dt)
{
    if (remote == null) return;
    if (remote.MoveIndicator.LengthSquared() > 0.05f || remote.RotationIndicator.LengthSquared() > 0.05f || Math.Abs(remote.RollIndicator) > 0.05f) {
        dockStraightActive = false;
        StopOverrides();
        Echo("[Dock] Straight approach canceled by pilot input.");
        return;
    }

    Vector3D stageDir = hasLiveConnectorOrientation ? liveConnectorForward : entry1Forward;
    Vector3D stagePoint = liveConnectorTarget + (Vector3D.Normalize(stageDir) * connectorApproachDistance);
    Vector3D connectorOffset = connector != null ? (connector.GetPosition() - remote.GetPosition()) : Vector3D.Zero;
    Vector3D targetRemotePos = stagePoint - connectorOffset;
    Vector3D toStage = targetRemotePos - remote.GetPosition();
    double progress = toStage.Length();
    gyroControl?.FaceVectors(entry1Forward, entry1Up, dt);
    if (progress <= 2.0) {
        dockStraightActive = false;
        dockActive = true;
        StopThrusterOverrides();
        Echo("[Dock] Staging point reached. Final connector approach.");
        return;
    }

    Vector3D desiredVel = Vector3D.Normalize(toStage) * MathHelper.Clamp(progress / 4.0, 0.25, 1.6);
    Vector3D velErr = desiredVel - remote.GetShipVelocities().LinearVelocity;
    List<IMyThrust> thrusters = new List<IMyThrust>();
    GridTerminalSystem.GetBlocksOfType(thrusters);
    foreach (var t in thrusters) {
        Vector3D accelDir = -t.WorldMatrix.Forward;
        double thrustDemand = Vector3D.Dot(velErr, accelDir);
        t.ThrustOverride = thrustDemand > 0.05 ? (float)(thrustDemand * 180000) : 0f;
    }
}

void ApplyDock(double dt)
{
    if (remote == null || !hasLiveConnectorTarget) {
        dockActive = false;
        StopOverrides();
        Echo("[Dock] Missing connector target.");
        return;
    }
    if (remote.MoveIndicator.LengthSquared() > 0.05f || remote.RotationIndicator.LengthSquared() > 0.05f || Math.Abs(remote.RollIndicator) > 0.05f) {
        dockActive = false;
        StopOverrides();
        Echo("[Dock] Canceled by pilot input.");
        return;
    }

    Vector3D connectorOffset = connector != null ? (connector.GetPosition() - remote.GetPosition()) : Vector3D.Zero;
    Vector3D targetRemotePos = liveConnectorTarget - connectorOffset;
    Vector3D delta = targetRemotePos - remote.GetPosition();
    double distance = delta.Length();

    // Keep refreshing Ca orientation/connector while in final stretch.
    if (distance <= DOCK_REFRESH_DISTANCE) {
        dockRefreshTimer += dt;
        if (dockRefreshTimer >= 0.5) {
            dockRefreshTimer = 0;
            BroadcastCarrier("LiveDockDataRequest");
        }
    }

    gyroControl?.FaceVectors(entry1Forward, entry1Up, dt);

    if (distance <= CONNECTOR_APPROACH_CLOSE) {
        dockActive = false;
        StopOverrides();
        if (connector != null && connector.Status == MyShipConnectorStatus.Connectable) connector.Connect();
        Echo("[Dock] Reached connector target.");
        return;
    }

    Vector3D desiredVel = Vector3D.Zero;
    if (distance > 0.01)
        desiredVel = Vector3D.Normalize(delta) * MathHelper.Clamp(distance / 5.0, 0.15, 1.1);
    Vector3D velErr = desiredVel - remote.GetShipVelocities().LinearVelocity;
    List<IMyThrust> thrusters = new List<IMyThrust>();
    GridTerminalSystem.GetBlocksOfType(thrusters);
    foreach (var t in thrusters) {
        Vector3D accelDir = -t.WorldMatrix.Forward;
        double thrustDemand = Vector3D.Dot(velErr, accelDir);
        t.ThrustOverride = thrustDemand > 0.05 ? (float)(thrustDemand * 180000) : 0f;
    }
}

void BeginUndoAndReturn() {
    // Remove local last path point to mirror undo intent.
    if (currentSitePathPoints.Count > 0) {
        int last = currentSitePathPoints.Count - 1;
        currentSitePathPoints.RemoveAt(last);
        currentSitePathForwards.RemoveAt(last);
        currentSitePathUps.RemoveAt(last);
    }

    undoReturnTargets.Clear();
    undoReturnForwards.Clear();
    undoReturnUps.Clear();
    undoReturnTargetIndex = 0;

    for (int i = currentSitePathPoints.Count - 1; i >= 0; i--) {
        undoReturnTargets.Add(currentSitePathPoints[i]);
        undoReturnForwards.Add(currentSitePathForwards[i]);
        undoReturnUps.Add(currentSitePathUps[i]);
    }

    if (hasLastStaggerPoint) {
        undoReturnTargets.Add(lastStaggerPos);
        undoReturnForwards.Add(autoReturnHoldForward);
        undoReturnUps.Add(autoReturnHoldUp);
    } else if (hasEntry1Target) {
        undoReturnTargets.Add(entry1Target);
        undoReturnForwards.Add(entry1Forward);
        undoReturnUps.Add(entry1Up);
    }

    if (undoReturnTargets.Count == 0) { Echo("[UndoReturn] No checkpoint to return to."); return; }
    undoReturnActive = true;
    Echo($"[UndoReturn] Reversing through {undoReturnTargets.Count} checkpoint(s).");
}

void ApplyUndoAndReturn(double dt) {
    if (undoReturnTargetIndex >= undoReturnTargets.Count) {
        undoReturnActive = false;
        StopOverrides();
        Echo("[UndoReturn] Completed.");
        return;
    }
    if (remote.MoveIndicator.LengthSquared() > 0.05f || remote.RotationIndicator.LengthSquared() > 0.05f || Math.Abs(remote.RollIndicator) > 0.05f) {
        undoReturnActive = false;
        StopOverrides();
        Echo("[UndoReturn] Canceled by pilot input.");
        return;
    }

    Vector3D targetPos = undoReturnTargets[undoReturnTargetIndex];
    Vector3D targetF = undoReturnForwards[undoReturnTargetIndex];
    Vector3D targetU = undoReturnUps[undoReturnTargetIndex];
    Vector3D delta = targetPos - remote.GetPosition();
    double distance = delta.Length();
    gyroControl?.FaceVectors(targetF, targetU, dt);

    if (distance <= UNDO_RETURN_POINT_CLOSE) {
        undoReturnTargetIndex++;
        StopThrusterOverrides();
        return;
    }

    Vector3D desiredVel = Vector3D.Zero;
    if (distance > 0.01)
        desiredVel = Vector3D.Normalize(delta) * MathHelper.Clamp(distance / 4.0, 0.4, AUTO_RETURN_MAX_SPEED);
    Vector3D velErr = desiredVel - remote.GetShipVelocities().LinearVelocity;

    List<IMyThrust> thrusters = new List<IMyThrust>();
    GridTerminalSystem.GetBlocksOfType(thrusters);
    foreach (var t in thrusters) {
        Vector3D accelDir = -t.WorldMatrix.Forward;
        double thrustDemand = Vector3D.Dot(velErr, accelDir);
        t.ThrustOverride = thrustDemand > 0.05 ? (float)(thrustDemand * 180000) : 0f;
    }
}

bool TryParseOrientation(string orientation, out Vector3D forward, out Vector3D up) {
    forward = Vector3D.Forward;
    up = Vector3D.Up;
    var p = orientation.Split(',');
    if (p.Length < 3) return false;
    double yawDeg, pitchDeg, rollDeg;
    if (!double.TryParse(p[0], out yawDeg)) return false;
    if (!double.TryParse(p[1], out pitchDeg)) return false;
    if (!double.TryParse(p[2], out rollDeg)) return false;
    MatrixD m = MatrixD.CreateFromYawPitchRoll(
        MathHelper.ToRadians((float)yawDeg),
        MathHelper.ToRadians((float)pitchDeg),
        MathHelper.ToRadians((float)rollDeg)
    );
    forward = Vector3D.Normalize(m.Forward);
    up = Vector3D.Normalize(m.Up);
    return true;
}

void HandleLiveDockData(string msg)
{
    var parts = msg.Split('|');
    if (parts.Length < 4) return;
    Vector3D p;
    if (TryParseGPS(parts[1], out p)) { entry1Target = p; hasEntry1Target = true; }
    Vector3D f, u;
    if (parts.Length >= 6 && TryParseVector3(parts[4], out f) && TryParseVector3(parts[5], out u)) {
        entry1Forward = Vector3D.Normalize(f);
        entry1Up = Vector3D.Normalize(u);
    } else if (TryParseOrientation(parts[2], out f, out u)) {
        entry1Forward = f;
        entry1Up = u;
    }
    if (TryParseGPS(parts[3], out p)) { liveConnectorTarget = p; hasLiveConnectorTarget = true; }
    if (parts.Length >= 8 && TryParseVector3(parts[6], out f) && TryParseVector3(parts[7], out u)) {
        liveConnectorForward = Vector3D.Normalize(f);
        liveConnectorUp = Vector3D.Normalize(u);
        hasLiveConnectorOrientation = true;
    }
    if (parts.Length >= 9) {
        double d;
        if (double.TryParse(parts[8], out d) && d >= 5.0) connectorApproachDistance = d;
    }
    if (pendingDockStart) StartDock();
}

void StopOverrides() { StopThrusterOverrides(); gyroControl?.Reset(); }
void StopThrusterOverrides() { foreach (var x in cachedThrusters) x.ThrustOverride = 0; }

bool TryParseGPS(string gps, out Vector3D pos) { 
    pos = Vector3D.Zero; var p = gps.Split(':'); if (p.Length < 5) return false; 
    return double.TryParse(p[2], out pos.X) && double.TryParse(p[3], out pos.Y) && double.TryParse(p[4], out pos.Z); 
} 

bool TryParseVector3(string raw, out Vector3D v) {
    v = Vector3D.Zero;
    var p = raw.Split(',');
    if (p.Length < 3) return false;
    return double.TryParse(p[0], out v.X) && double.TryParse(p[1], out v.Y) && double.TryParse(p[2], out v.Z);
}

void GetRotationAngles(Vector3D forward, Vector3D up, out double yaw, out double pitch, out double roll) { 
    Vector3D left = Vector3D.Cross(up, forward); forward.Normalize(); up.Normalize(); left.Normalize(); 
    yaw = Math.Atan2(forward.X, forward.Z) * (180 / Math.PI); pitch = Math.Asin(forward.Y) * (180 / Math.PI); roll = Math.Atan2(left.Y, up.Y) * (180 / Math.PI); 
}

