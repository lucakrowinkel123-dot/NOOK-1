const string LCD_PATH_NAME = "ANOUK-PF LCD 1"; 
const string LCD_CONFIRM_NAME = "ANOUK-PF LCD 2"; 
const string INDICATOR_NAME = "ANOUK-PF Indicator Light"; 
const string SOUND_BLOCK_NAME = "ANOUK-PF Sound Block"; 
const string SENSOR_TAG = "ANOUK-PF Sensor"; // Ensure your sensor has this name
const string PATHFINDER_CHANNEL = "ANOUK-Ca_PathFinder_Channel"; 
const string REMOTE_TAG = "ANOUK-PF Remote Control"; 
const double CLOSE_ENOUGH_DEFAULT = 1.0; 

// PID TUNING FOR STABILITY
const double gyroP = 0.5; const double gyroI = 0.002; const double gyroD = 0.5; const double gyroMax = 2;

IMyTextPanel lcdPath; IMyTextPanel lcdConfirm; IMyLightingBlock indicatorLight; IMySoundBlock soundBlock; IMyRemoteControl remote; 
IMySensorBlock sensor; // Added sensor reference
GyroControl gyroControl;

bool blinkRequested = false; int blinkTicks = 0; Color blinkColor = new Color(0, 255, 0); 

// Path data 
List<Vector3D> pathGPS = new List<Vector3D>(); 
List<string> pathGPSStrings = new List<string>(); 
List<string> pathOrientations = new List<string>(); 
List<double> pathCloseEnoughs = new List<double>(); 
double pathMaxSpeed = -1; 

// ---- RECORDING MODE STATE ---- 
bool recordingActive = false; bool recordingPaused = false; 
Vector3D recordingLastGPS = Vector3D.Zero; double recordingTimer = 0; 
const double RECORDING_INTERVAL = 10.0; const double RECORDING_DISTANCE = 25.0; 

// ---- NEW SETUP STATE ----
bool isSoftLocked = false;
Vector3D lockedPos;
MatrixD lockedMatrix;
int setupStep = 0;
Vector3D setupPos1 = Vector3D.Zero;
Vector3D setupPos2 = Vector3D.Zero;

public Program() { 
    Runtime.UpdateFrequency = UpdateFrequency.Update10; 
    IGC.RegisterBroadcastListener(PATHFINDER_CHANNEL); 
} 

public void Main(string argument, UpdateType updateSource) { 
    lcdPath = GridTerminalSystem.GetBlockWithName(LCD_PATH_NAME) as IMyTextPanel; 
    lcdConfirm = GridTerminalSystem.GetBlockWithName(LCD_CONFIRM_NAME) as IMyTextPanel; 
    indicatorLight = GridTerminalSystem.GetBlockWithName(INDICATOR_NAME) as IMyLightingBlock; 
    remote = GridTerminalSystem.GetBlockWithName(REMOTE_TAG) as IMyRemoteControl; 
    sensor = GridTerminalSystem.GetBlockWithName(SENSOR_TAG) as IMySensorBlock; // Initialize sensor
    soundBlock = GridTerminalSystem.GetBlockWithName(SOUND_BLOCK_NAME) as IMySoundBlock; 

    if (remote != null && gyroControl == null) {
        List<IMyGyro> gyros = new List<IMyGyro>();
        GridTerminalSystem.GetBlocksOfType(gyros);
        gyroControl = new GyroControl(remote, gyros);
    }

    double deltaTime = Runtime.TimeSinceLastRun.TotalSeconds; 
    string cmd = (argument ?? "").Trim(); 
    string commandPrefix = null; 
    bool isSendCommand = false; 

    // --- NEW 3-STEP SETUP WITH SENSOR VISUALS ---
    if (cmd.Equals("PF_ExcavationSiteSetUpComplete", StringComparison.OrdinalIgnoreCase)) {
        if (remote == null) return;
        setupStep++;
        if (setupStep == 1) {
            isSoftLocked = true;
            lockedPos = remote.GetPosition();
            lockedMatrix = remote.WorldMatrix;
            ConfigureSensorVisuals(true); // TURN ON VISUAL GUIDE
            Echo("Step 1: Locked. Visuals On. Go to A.");
        } else if (setupStep == 2) {
            setupPos1 = remote.GetPosition();
            Echo("Step 2: A Set. Go to B.");
        } else if (setupStep == 3) {
            setupPos2 = remote.GetPosition();
            double y, p, r; GetRotationAngles(lockedMatrix.Forward, lockedMatrix.Up, out y, out p, out r);
            string orient = $"{y:F2},{p:F2},{r:F2}";
            string gpsA = $"GPS:CornerA:{setupPos1.X:F2}:{setupPos1.Y:F2}:{setupPos1.Z:F2}:";
            string gpsB = $"GPS:CornerB:{setupPos2.X:F2}:{setupPos2.Y:F2}:{setupPos2.Z:F2}:";
            string msg = $"ExcavationSiteSetUpComplete|{orient}|{gpsA}|{gpsB}";
            IGC.SendBroadcastMessage(PATHFINDER_CHANNEL, msg);
            Echo($"Sent Setup: {msg}");
            setupStep = 0; isSoftLocked = false; 
            ConfigureSensorVisuals(false); // TURN OFF VISUAL GUIDE
            StopOverrides();
        }
    }

    // --- STANDARD COMMANDS --- 
    else if (cmd.Equals("PF_ExcavationSitePathAdd", StringComparison.OrdinalIgnoreCase)) { commandPrefix = "ExcavationSitePathAdd"; isSendCommand = true; } 
    else if (cmd.Equals("PF_ExcavationSiteStagger", StringComparison.OrdinalIgnoreCase)) { 
        commandPrefix = "ExcavationSiteStagger"; isSendCommand = true; 
        if (recordingActive) StopRecordingMode(); 
        ConfigureSensorVisuals(true); // Turn on visuals for stagger alignment
    } 
    else if (cmd.Equals("PF_ExcavationSiteCancel", StringComparison.OrdinalIgnoreCase)) { 
        commandPrefix = "ExcavationSiteCancel"; isSendCommand = true; 
        if (recordingActive) StopRecordingMode();
        isSoftLocked = false; setupStep = 0; 
        ConfigureSensorVisuals(false); // Clean up visuals
        StopOverrides();
    } 
    else if (cmd.Equals("PF_ReturnRequest", StringComparison.OrdinalIgnoreCase)) { commandPrefix = "PathfinderReturnRequest"; isSendCommand = true; } 
    else if (cmd.Equals("PF_MaxSpeedRequest", StringComparison.OrdinalIgnoreCase)) { commandPrefix = "PathfinderMaxSpeedRequest"; isSendCommand = true; } 
    else if (cmd.Equals("PF_ExcavationSitePathStartRecording", StringComparison.OrdinalIgnoreCase)) { StartRecordingMode(); } 
    else if (cmd.Equals("PF_ExcavationSitePathStopRecording", StringComparison.OrdinalIgnoreCase)) { StopRecordingMode(); } 

    // --- SEND COMMAND --- 
    if (isSendCommand) { 
        string msg; 
        if (commandPrefix == "ExcavationSitePathAdd" || commandPrefix == "ExcavationSiteStagger") { 
            if (remote == null) { Echo("No remote found!"); return; } 
            var pos = remote.GetPosition(); 
            string gps = $"GPS:Site:{pos.X:F2}:{pos.Y:F2}:{pos.Z:F2}:"; 
            double yaw, pitch, roll; GetRotationAngles(remote.WorldMatrix.Forward, remote.WorldMatrix.Up, out yaw, out pitch, out roll); 
            string orient = $"{yaw:F2},{pitch:F2},{roll:F2}"; 
            msg = $"{commandPrefix}|{gps}|{orient}"; 
        } else { msg = commandPrefix; } 
        IGC.SendBroadcastMessage(PATHFINDER_CHANNEL, msg); Echo($"Sent: {msg}"); 
    } 

    // --- IGC LISTENING --- 
    var listeners = new List<IMyBroadcastListener>(); IGC.GetBroadcastListeners(listeners); 
    foreach (var listener in listeners) { 
        while (listener.HasPendingMessage) { 
            var m = listener.AcceptMessage(); string str = m.Data as string; 
            if (str != null) { 
                if (str.StartsWith("Confirmed_Entry|")) HandleConfirmedEntry(str); 
                else if (str.StartsWith("Path|")) HandlePathMessage(str); 
                else if (str.StartsWith("PathfinderMaxSpeed|")) HandleMaxSpeed(str); 
            } 
        } 
    } 

    // --- BLINK --- 
    if (blinkRequested && indicatorLight != null) { blinkTicks++; if (blinkTicks >= 5) { indicatorLight.Enabled = false; blinkRequested = false; } } 

    // --- SOFT LOCK & RECORDING LOGIC --- 
    if (isSoftLocked && remote != null) ApplySoftLock(deltaTime);

    if (recordingActive && !recordingPaused && remote != null) { 
        recordingTimer += deltaTime; 
        if (recordingTimer >= RECORDING_INTERVAL) { 
            var dist = (remote.GetPosition() - recordingLastGPS).Length(); 
            if (dist >= RECORDING_DISTANCE) { SendPFExcavationSitePathAdd(); recordingPaused = true; } 
        } 
    } 
    OutputPathStatus(); 
} 

// --- SENSOR CONFIGURATION HELPER ---
void ConfigureSensorVisuals(bool active) {
    if (sensor == null) return;
    if (active) {
        sensor.FrontExtend = 50f;
        sensor.BackExtend = 0.1f;
        sensor.LeftExtend = 0.1f;
        sensor.RightExtend = 0.1f;
        sensor.TopExtend = 0.1f;
        sensor.BottomExtend = 0.1f;
        sensor.Enabled = true;
        sensor.ShowOnHUD = true;
    } else {
        sensor.Enabled = false;
        sensor.ShowOnHUD = false;
    }
}

