class GyroControl {
    private List<IMyGyro> gyros; IMyRemoteControl rc; PID X, Y, Z;
    public GyroControl(IMyRemoteControl rc, List<IMyGyro> gyros) {
        this.rc = rc; this.gyros = gyros;
        X = new PID(gyroP, gyroI, gyroD, -gyroMax, gyroMax);
        Y = new PID(gyroP, gyroI, gyroD, -gyroMax, gyroMax);
        Z = new PID(gyroP, gyroI, gyroD, -gyroMax, gyroMax);
    }
    public void Reset() { foreach (var g in gyros) g.GyroOverride = false; X.Reset(); Y.Reset(); Z.Reset(); }
    public void FaceVectors(Vector3D f, Vector3D u, double dt) {
        Vector3D e = -GetAngles(rc.WorldMatrix, f, u);
        Vector3D outV = new Vector3D(X.Compute(e.X, dt), Y.Compute(e.Y, dt), Z.Compute(e.Z, dt));
        Vector3D wV = Vector3D.TransformNormal(outV, rc.WorldMatrix);
        foreach (var g in gyros) {
            Vector3D l = Vector3D.TransformNormal(wV, MatrixD.Transpose(g.WorldMatrix));
            g.Pitch = (float)l.X; g.Yaw = (float)l.Y; g.Roll = (float)l.Z; g.GyroOverride = true;
        }
    }
    Vector3D GetAngles(MatrixD m, Vector3D f, Vector3D u) {
        Vector3D lF = Vector3D.Transform(f, Quaternion.Inverse(Quaternion.CreateFromForwardUp(m.Forward, m.Up)));
        double y, p; Vector3D.GetAzimuthAndElevation(lF, out y, out p);
        Vector3D pU = Vector3D.Normalize(u - (Vector3D.Dot(u, m.Forward) * m.Forward));
        double r = Math.Acos(MathHelper.Clamp(Vector3D.Dot(m.Up, pU), -1, 1));
        if (Vector3D.Dot(pU, m.Right) > 0) r *= -1;
        return new Vector3D(p, y, r);
    }
}
class PID {
    double _kp, _ki, _kd, _min, _max, _int, _lastE; bool _f = true;
    public PID(double p, double i, double d, double min, double max) { _kp=p; _ki=i; _kd=d; _min=min; _max=max; }
    public double Compute(double e, double dt) {
        if (dt <= 0) return 0;
        _int = MathHelper.Clamp(_int + (e * dt), _min, _max);
        double der = _f ? 0 : (e - _lastE) / dt; _lastE = e; _f = false;
        return MathHelper.Clamp((e * _kp) + (_int * _ki) + (der * _kd), _min, _max);
    }
    public void Reset() { _int = 0; _lastE = 0; _f = true; }
}
