void ApplySoftLock(double dt) {
    if (remote.RotationIndicator.LengthSquared() < 0.01f && Math.Abs(remote.RollIndicator) < 0.01f) {
        gyroControl?.FaceVectors(lockedMatrix.Forward, lockedMatrix.Up, dt);
    } else gyroControl?.Reset();

    Vector3D deltaPos = lockedPos - remote.GetPosition();
    double fwdErr = Vector3D.Dot(deltaPos, remote.WorldMatrix.Forward);
    if (Math.Abs(remote.MoveIndicator.Z) < 0.1f) {
        double cVel = Vector3D.Dot(remote.GetShipVelocities().LinearVelocity, remote.WorldMatrix.Forward);
        double tVel = MathHelper.Clamp((fwdErr / 5.0) * 2.0, -3.0, 3.0);
        double vErr = tVel - cVel;
        double gain = GetThrustGain();
        foreach (var t in cachedThrusters) {
            if (Vector3D.Dot(t.WorldMatrix.Forward, remote.WorldMatrix.Backward) > 0.9) t.ThrustOverride = vErr > 0.05 ? (float)(vErr * gain) : 0;
            if (Vector3D.Dot(t.WorldMatrix.Forward, remote.WorldMatrix.Forward) > 0.9) t.ThrustOverride = vErr < -0.05 ? (float)(Math.Abs(vErr) * gain) : 0;
        }
    } else StopThrusterOverrides();
}

void StartAutoReturnToStagger() {
    if (!hasLastStaggerPoint || remote == null) return;
    autoReturnToStaggerActive = true;
    Echo("[AutoReturn] Navigating to stagger point...");
}

void ApplyAutoReturnToStagger(double dt) {
    if (remote == null) return;
    if (remote.MoveIndicator.LengthSquared() > 0.05f || remote.RotationIndicator.LengthSquared() > 0.05f || Math.Abs(remote.RollIndicator) > 0.05f) {
        autoReturnToStaggerActive = false;
        StopOverrides();
        Echo("[AutoReturn] Canceled by pilot input.");
        return;
    }

    Vector3D delta = lastStaggerPos - remote.GetPosition();
    double distance = delta.Length();
    if (distance <= AUTO_RETURN_CLOSE) {
        autoReturnToStaggerActive = false;
        StopOverrides(); // release control back to pilot
        currentSitePathPoints.Clear();
        currentSitePathForwards.Clear();
        currentSitePathUps.Clear();
        if (!recordingActive) StartRecordingMode();
        Echo("[AutoReturn] Reached stagger point. Pilot control restored. Recording started.");
        return;
    }

    // Keep the excavation-complete orientation for the full move.
    gyroControl?.FaceVectors(autoReturnHoldForward, autoReturnHoldUp, dt);

    Vector3D desiredVel = Vector3D.Zero;
    if (distance > 0.01)
        desiredVel = Vector3D.Normalize(delta) * MathHelper.Clamp(distance / 4.0, 0.4, AUTO_RETURN_MAX_SPEED);
    Vector3D velErr = desiredVel - remote.GetShipVelocities().LinearVelocity;

    List<IMyThrust> thrusters = new List<IMyThrust>(); 
    GridTerminalSystem.GetBlocksOfType(thrusters);
    foreach (var t in thrusters) {
        Vector3D accelDir = -t.WorldMatrix.Forward;
        double thrustDemand = Vector3D.Dot(velErr, accelDir);
        t.ThrustOverride = thrustDemand > 0.05 ? (float)(thrustDemand * 180000) : 0f;
    }
}

void StartRecordingMode() { recordingActive = true; recordingPaused = true; recordingTimer = 0; recordingLastGPS = remote != null ? remote.GetPosition() : Vector3D.Zero; SendPFExcavationSitePathAdd(); Echo("[Recording Mode] Started."); } 
void StopRecordingMode() { recordingActive = false; recordingPaused = false; recordingTimer = 0; recordingLastGPS = Vector3D.Zero; Echo("[Recording Mode] Stopped."); } 

void SendPFExcavationSitePathAdd() { 
    if (remote == null) return; 
    string gps = $"GPS:Site:{remote.GetPosition().X:F2}:{remote.GetPosition().Y:F2}:{remote.GetPosition().Z:F2}:"; 
    double yaw, pitch, roll; GetRotationAngles(remote.WorldMatrix.Forward, remote.WorldMatrix.Up, out yaw, out pitch, out roll); 
    string orient = $"{yaw:F2},{pitch:F2},{roll:F2}"; 
    string msg = $"ExcavationSitePathAdd|{gps}|{orient}"; 
    BroadcastCarrier(msg); Echo($"[Recording] Sent: {msg}"); 
} 

void HandleMaxSpeed(string msg) { 
    var parts = msg.Split('|'); if (parts.Length < 2) return; 
    double speed; if (double.TryParse(parts[1], out speed)) { pathMaxSpeed = speed; Echo($"Received max speed: {speed}"); } 
} 

void HandlePathMessage(string msg) { 
    var parts = msg.Split('|'); if (parts.Length < 3) return; 
    pathGPS.Clear(); pathGPSStrings.Clear(); pathOrientations.Clear(); pathCloseEnoughs.Clear(); 
    int idx = 1; while (idx + 1 < parts.Length) { 
        string gps = parts[idx++]; string orient = parts[idx++]; pathGPSStrings.Add(gps); pathOrientations.Add(orient); 
        Vector3D pos; if (TryParseGPS(gps, out pos)) pathGPS.Add(pos); 
        double closeEnough = CLOSE_ENOUGH_DEFAULT; 
        if (idx < parts.Length && double.TryParse(parts[idx], out closeEnough)) { pathCloseEnoughs.Add(closeEnough); idx++; } else { pathCloseEnoughs.Add(CLOSE_ENOUGH_DEFAULT); } 
    } 
    pathMaxSpeed = -1; BroadcastCarrier("PathfinderMaxSpeedRequest"); Echo("Path stored."); 
    if (autominePendingPath && pathGPS.Count > 0) {
        autominePendingPath = false;
        bool firstIsEntry = pathGPSStrings.Count > 0 && pathGPSStrings[0].StartsWith("GPS:Entry:", StringComparison.OrdinalIgnoreCase);
        autominePathIndex = firstIsEntry ? 1 : 0;
        if (automineStartAfterUndock && (undockActive || undockToEntryActive)) {
            Echo($"[AutoMine] Path loaded ({pathGPS.Count} points). Waiting for PF_Undock takeover.");
        } else {
            automineActive = true;
            automineStartAfterUndock = false;
            Echo($"[AutoMine] Path loaded ({pathGPS.Count} points).");
        }
    }
} 

void StartAutomine() {
    autominePendingPath = true;
    autominePathIndex = 0;
    automineStartAfterUndock = undockActive || undockToEntryActive;
    BroadcastCarrier("PathfinderReturnRequest");
    Echo("[AutoMine] Requested path from Ca.");
}

void StopAutomine(bool clearPending) {
    automineActive = false;
    if (clearPending) autominePendingPath = false;
    automineStartAfterUndock = false;
    autominePathIndex = 0;
    StopOverrides();
    Echo("[AutoMine] Stopped.");
}

Vector3D GetDrillCenterOrRemote() {
    if (remote == null) return Vector3D.Zero;
    List<IMyShipDrill> drills = new List<IMyShipDrill>();
    GridTerminalSystem.GetBlocksOfType(drills, d => d.CubeGrid == remote.CubeGrid);
    if (drills.Count == 0) return remote.GetPosition();
    Vector3D rp = remote.GetPosition();
    Vector3D left = remote.WorldMatrix.Left;
    Vector3D up = remote.WorldMatrix.Up;
    Vector3D fwd = remote.WorldMatrix.Forward;
    double minL = double.MaxValue, maxL = double.MinValue;
    double minU = double.MaxValue, maxU = double.MinValue;
    double minF = double.MaxValue, maxF = double.MinValue;
    foreach (var d in drills) {
        Vector3D rel = d.GetPosition() - rp;
        double l = Vector3D.Dot(rel, left);
        double u = Vector3D.Dot(rel, up);
        double f = Vector3D.Dot(rel, fwd);
        if (l < minL) minL = l; if (l > maxL) maxL = l;
        if (u < minU) minU = u; if (u > maxU) maxU = u;
        if (f < minF) minF = f; if (f > maxF) maxF = f;
    }
    return rp + left * ((minL + maxL) * 0.5) + up * ((minU + maxU) * 0.5) + fwd * ((minF + maxF) * 0.5);
}

void ApplyAutomineFollow(double dt) {
    if (remote == null || !automineActive) return;
    if (autominePathIndex >= pathGPS.Count) { StopAutomine(false); Echo("[AutoMine] Path complete."); return; }
    if (remote.MoveIndicator.LengthSquared() > 0.05f || remote.RotationIndicator.LengthSquared() > 0.05f || Math.Abs(remote.RollIndicator) > 0.05f) {
        StopAutomine(true);
        Echo("[AutoMine] Canceled by pilot input.");
        return;
    }
    Vector3D target = pathGPS[autominePathIndex];
    double close = autominePathIndex < pathCloseEnoughs.Count ? pathCloseEnoughs[autominePathIndex] : CLOSE_ENOUGH_DEFAULT;
    Vector3D center = GetDrillCenterOrRemote();
    Vector3D offset = center - remote.GetPosition();
    Vector3D targetRemotePos = target - offset;
    Vector3D delta = targetRemotePos - remote.GetPosition();
    double distance = delta.Length();

    Vector3D faceDir = distance > 0.01 ? Vector3D.Normalize(delta) : remote.WorldMatrix.Forward;
    gyroControl?.FaceVectors(faceDir, remote.WorldMatrix.Up, dt);

    if (distance <= close) {
        autominePathIndex++;
        StopThrusterOverrides();
        return;
    }

    Vector3D desiredVel = Vector3D.Normalize(delta) * MathHelper.Clamp(distance / 4.0, 0.2, 1.8);
    Vector3D velErr = desiredVel - remote.GetShipVelocities().LinearVelocity;
    List<IMyThrust> thrusters = new List<IMyThrust>();
    GridTerminalSystem.GetBlocksOfType(thrusters);
    foreach (var t in thrusters) {
        Vector3D accelDir = -t.WorldMatrix.Forward;
        double thrustDemand = Vector3D.Dot(velErr, accelDir);
        t.ThrustOverride = thrustDemand > 0.05 ? (float)(thrustDemand * 180000) : 0f;
    }
}

