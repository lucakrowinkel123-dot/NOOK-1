double GetThrustGain()
{
    if (remote == null) return THRUST_GAIN_MIN;
    double mass = remote.CalculateShipMass().PhysicalMass;
    return MathHelper.Clamp(mass * THRUST_GAIN_PER_KG, THRUST_GAIN_MIN, THRUST_GAIN_MAX);
}

void ApplyVelocityError(Vector3D velErr)
{
    double gain = GetThrustGain();
    foreach (var t in cachedThrusters) {
        Vector3D accelDir = -t.WorldMatrix.Forward;
        double thrustDemand = Vector3D.Dot(velErr, accelDir);
        t.ThrustOverride = thrustDemand > 0.05 ? (float)(thrustDemand * gain) : 0f;
    }
}

