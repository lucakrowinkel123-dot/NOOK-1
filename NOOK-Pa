    if (lcdPath == null) return; 
    string outText = isSoftLocked ? $"[LOCKED - STEP {setupStep}]\n" : "";
    if (pathGPSStrings.Count > 0) { outText += "PATH:\n"; for (int i = 0; i < pathGPSStrings.Count; i++) outText += $"#{i + 1}: {pathGPSStrings[i]} | {pathOrientations[i]}\n"; } 
    else outText += "No path.\n"; 
    outText += $"Max Speed: {(pathMaxSpeed >= 0 ? pathMaxSpeed.ToString("0.##") : "N/A")}\n";
    outText += $"Runtime: {Runtime.LastRunTimeMs:0.000} ms\n";
    outText += $"Instr: {Runtime.CurrentInstructionCount}/{Runtime.MaxInstructionCount}\n"; 
