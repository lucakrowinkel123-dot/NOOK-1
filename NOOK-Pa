public void Main(string argument, UpdateType updateSource) { 
    lcdPath = GridTerminalSystem.GetBlockWithName(LCD_PATH_NAME) as IMyTextPanel; 
    lcdConfirm = GridTerminalSystem.GetBlockWithName(LCD_CONFIRM_NAME) as IMyTextPanel; 
    indicatorLight = GridTerminalSystem.GetBlockWithName(INDICATOR_NAME) as IMyLightingBlock; 
    remote = GridTerminalSystem.GetBlockWithName(REMOTE_TAG) as IMyRemoteControl; 
    sensor = GridTerminalSystem.GetBlockWithName(SENSOR_TAG) as IMySensorBlock; // Initialize sensor
    soundBlock = GridTerminalSystem.GetBlockWithName(SOUND_BLOCK_NAME) as IMySoundBlock; 
    connector = GridTerminalSystem.GetBlockWithName(CONNECTOR_TAG) as IMyShipConnector;

    if (remote != null && gyroControl == null) {
        List<IMyGyro> gyros = new List<IMyGyro>();
        GridTerminalSystem.GetBlocksOfType(gyros);
        gyroControl = new GyroControl(remote, gyros);
    }

    double deltaTime = Runtime.TimeSinceLastRun.TotalSeconds; 
    string cmd = (argument ?? "").Trim(); 
    string commandPrefix = null; 
    bool isSendCommand = false; 

    // --- NEW 3-STEP SETUP WITH SENSOR VISUALS ---
    if (CmdIs(cmd, "EMMA_ExcavationSiteSetUpComplete", "PF_ExcavationSiteSetUpComplete")) {
        if (remote == null) return;
        setupStep++;
        if (setupStep == 1) {
            isSoftLocked = true;
            lockedPos = remote.GetPosition();
            lockedMatrix = remote.WorldMatrix;
            ConfigureSensorVisuals(true); // TURN ON VISUAL GUIDE
            Echo("Step 1: Locked. Visuals On. Go to A.");
        } else if (setupStep == 2) {
            setupPos1 = remote.GetPosition();
            Echo("Step 2: A Set. Go to B.");
        } else if (setupStep == 3) {
            setupPos2 = remote.GetPosition();
            double y, p, r; GetRotationAngles(lockedMatrix.Forward, lockedMatrix.Up, out y, out p, out r);
            string orient = $"{y:F2},{p:F2},{r:F2}";
            string gpsA = $"GPS:CornerA:{setupPos1.X:F2}:{setupPos1.Y:F2}:{setupPos1.Z:F2}:";
            string gpsB = $"GPS:CornerB:{setupPos2.X:F2}:{setupPos2.Y:F2}:{setupPos2.Z:F2}:";
            string msg = $"ExcavationSiteSetUpComplete|{orient}|{gpsA}|{gpsB}";
            BroadcastCarrier(msg);
            Echo($"Sent Setup: {msg}");
            autoReturnHoldForward = lockedMatrix.Forward;
            autoReturnHoldUp = lockedMatrix.Up;
            entry1ProximityEnabled = true;
            setupStep = 0; isSoftLocked = false; 
            ConfigureSensorVisuals(false); // TURN OFF VISUAL GUIDE
            StopOverrides();
            StartAutoReturnToStagger();
        }
    }

    // --- STANDARD COMMANDS --- 
    else if (CmdIs(cmd, "EMMA_ExcavationSitePathAdd", "PF_ExcavationSitePathAdd")) { commandPrefix = "ExcavationSitePathAdd"; isSendCommand = true; } 
    else if (CmdIs(cmd, "EMMA_ExcavationSiteStagger", "PF_ExcavationSiteStagger")) { 
        commandPrefix = "ExcavationSiteStagger"; isSendCommand = true; 
        if (recordingActive) StopRecordingMode(); 
        ConfigureSensorVisuals(true); // Turn on visuals for stagger alignment
    } 
    else if (CmdIs(cmd, "EMMA_ExcavationSiteCancel", "PF_ExcavationSiteCancel")) { 
        commandPrefix = "ExcavationSiteCancel"; isSendCommand = true; 
        if (recordingActive) StopRecordingMode();
        autoReturnToStaggerActive = false;
        undoReturnActive = false;
        undockActive = false;
        undockToEntryActive = false;
        dockActive = false;
        dockStraightActive = false;
        automineActive = false;
        autominePendingPath = false;
        automineStartAfterUndock = false;
        autominePathIndex = 0;
        pendingDockStart = false;
        hasLiveConnectorOrientation = false;
        undockLiveRefreshTimer = 0;
        undoReturnTargets.Clear(); undoReturnForwards.Clear(); undoReturnUps.Clear(); undoReturnTargetIndex = 0;
        currentSitePathPoints.Clear(); currentSitePathForwards.Clear(); currentSitePathUps.Clear();
        isSoftLocked = false; setupStep = 0; 
        ConfigureSensorVisuals(false); // Clean up visuals
        StopOverrides();
    } 
    else if (cmd.Equals("PF_ExcavationSitePathUndo", StringComparison.OrdinalIgnoreCase)) {
        commandPrefix = "ExcavationSitePathUndo"; isSendCommand = true;
        if (recordingActive) StopRecordingMode();
    }
    else if (cmd.Equals("PF_ExcavationSitePathUndoAndReturn", StringComparison.OrdinalIgnoreCase)) {
        commandPrefix = "ExcavationSitePathUndo"; isSendCommand = true;
        if (recordingActive) StopRecordingMode();
        BeginUndoAndReturn();
    }
    else if (cmd.Equals("PF_AsteroidSetUpCancel", StringComparison.OrdinalIgnoreCase)) { commandPrefix = "AsteroidSetUpCancel"; isSendCommand = true; }
    else if (cmd.Equals("PF_Undock", StringComparison.OrdinalIgnoreCase)) { StartUndock(); return; }
    else if (cmd.Equals("PF_AutoMineStart", StringComparison.OrdinalIgnoreCase)) { StartAutomine(); return; }
    else if (cmd.Equals("PF_AutoMineStop", StringComparison.OrdinalIgnoreCase)) { StopAutomine(true); return; }
    else if (cmd.Equals("PF_Dock", StringComparison.OrdinalIgnoreCase)) {
        pendingDockStart = true;
        BroadcastCarrier("LiveDockDataRequest");
        return;
    }
    else if (CmdIs(cmd, "EMMA_ReturnRequest", "PF_ReturnRequest")) { commandPrefix = "PathfinderReturnRequest"; isSendCommand = true; } 
    else if (CmdIs(cmd, "EMMA_MaxSpeedRequest", "PF_MaxSpeedRequest")) { commandPrefix = "PathfinderMaxSpeedRequest"; isSendCommand = true; } 
    else if (CmdIs(cmd, "EMMA_AsteroidSetUpComplete", "PF_AsteroidSetUpComplete")) { commandPrefix = "AsteroidSetUpComplete"; isSendCommand = true; }
    else if (cmd.Equals("PF_Reset", StringComparison.OrdinalIgnoreCase)) { ResetPathfinder(true); return; }
    else if (CmdIs(cmd, "EMMA_ExcavationSitePathStartRecording", "PF_ExcavationSitePathStartRecording")) { StartRecordingMode(); } 
    else if (CmdIs(cmd, "EMMA_ExcavationSitePathStopRecording", "PF_ExcavationSitePathStopRecording")) { StopRecordingMode(); } 

    // --- SEND COMMAND --- 
    if (isSendCommand) { 
        string msg; 
        if (commandPrefix == "ExcavationSitePathAdd" || commandPrefix == "ExcavationSiteStagger") { 
            if (remote == null) { Echo("No remote found!"); return; } 
            var pos = remote.GetPosition(); 
            if (commandPrefix == "ExcavationSiteStagger") { 
                lastStaggerPos = pos; 
                autoReturnHoldForward = remote.WorldMatrix.Forward;
                autoReturnHoldUp = remote.WorldMatrix.Up;
                hasLastStaggerPoint = true; 
            }
            if (commandPrefix == "ExcavationSitePathAdd") {
                currentSitePathPoints.Add(pos);
                currentSitePathForwards.Add(remote.WorldMatrix.Forward);
                currentSitePathUps.Add(remote.WorldMatrix.Up);
            }
            string gps = $"GPS:Site:{pos.X:F2}:{pos.Y:F2}:{pos.Z:F2}:"; 
            double yaw, pitch, roll; GetRotationAngles(remote.WorldMatrix.Forward, remote.WorldMatrix.Up, out yaw, out pitch, out roll); 
            string orient = $"{yaw:F2},{pitch:F2},{roll:F2}"; 
            msg = $"{commandPrefix}|{gps}|{orient}"; 
        } else { msg = commandPrefix; } 
        BroadcastCarrier(msg); Echo($"Sent: {msg}"); 
    } 

    // --- IGC LISTENING --- 
    var listeners = new List<IMyBroadcastListener>(); IGC.GetBroadcastListeners(listeners); 
    foreach (var listener in listeners) { 
        while (listener.HasPendingMessage) { 
            var m = listener.AcceptMessage(); string str = m.Data as string; 
            if (str != null) { 
                if (str.StartsWith("Confirmed_Entry|")) HandleConfirmedEntry(str); 
                else if (str.StartsWith("Path|")) HandlePathMessage(str); 
                else if (str.StartsWith("ActiveAsteroidSnapshot|")) HandleAsteroidSnapshotMessage(str);
                else if (str.StartsWith("PathfinderMaxSpeed|")) HandleMaxSpeed(str); 
                else if (str.StartsWith("LiveDockData|")) HandleLiveDockData(str);
            } 
        } 
    } 

    // --- BLINK --- 
    if (blinkRequested && indicatorLight != null) { blinkTicks++; if (blinkTicks >= 5) { indicatorLight.Enabled = false; blinkRequested = false; } } 
    if (!blinkRequested) {
        bool apLight = UpdateAutopilotIndicator();
        if (!apLight) UpdateEntry1ProximityIndicator();
    }

    // --- SOFT LOCK & RECORDING LOGIC --- 
    if (isSoftLocked && remote != null) ApplySoftLock(deltaTime);
    if (autoReturnToStaggerActive && remote != null) ApplyAutoReturnToStagger(deltaTime);
    if (undoReturnActive && remote != null) ApplyUndoAndReturn(deltaTime);
    if (undockActive && remote != null) ApplyUndock(deltaTime);
    if (undockToEntryActive && remote != null) ApplyUndockToEntry(deltaTime);
    if (dockStraightActive && remote != null) ApplyDockStraight(deltaTime);
    if (dockActive && remote != null) ApplyDock(deltaTime);
    if (automineActive && remote != null) ApplyAutomineFollow(deltaTime);
    if (automineStartAfterUndock && !automineActive && !autominePendingPath && !undockActive && !undockToEntryActive && pathGPS.Count > 0) {
        automineStartAfterUndock = false;
        automineActive = true;
        Echo("[AutoMine] Undock complete. Automine path takeover active.");
    }

    if (recordingActive && !recordingPaused && remote != null) { 
        recordingTimer += deltaTime; 
        if (recordingTimer >= RECORDING_INTERVAL) { 
            var dist = (remote.GetPosition() - recordingLastGPS).Length(); 
            if (dist >= RECORDING_DISTANCE) { SendPFExcavationSitePathAdd(); recordingPaused = true; } 
        } 
    } 
    OutputPathStatus(); 
    PrintDebugState();
} 

bool CmdIs(string cmd, string primary, string legacy) {
    return cmd.Equals(primary, StringComparison.OrdinalIgnoreCase) ||
           cmd.Equals(legacy, StringComparison.OrdinalIgnoreCase);
}

